# ── App ──
APP_ENV=production
APP_BASE_URL=https://app.your-domain.com
APP_SECRET_KEY=            # openssl rand -hex 32
JWT_SECRET=                # openssl rand -hex 32
# ── Data ──
POSTGRES_USER=             # make env-init sets: rpim
POSTGRES_PASSWORD=         # make env-init generates (openssl rand -hex 32)
POSTGRES_DB=               # make env-init sets: rpim
DATABASE_URL=              # make env-init composes; in-compose host is `postgres`
REDIS_URL=redis://localhost:6379/0  # inside compose the service hostname `redis` is set per-service
# ── Domestic channels ──
BALE_BOT_TOKEN=
EITAA_TOKEN=
ZARINPAL_MERCHANT_ID=      # end of phase 1
KAVENEGAR_API_KEY=         # phase 2
# ── Bridge to US leg ──
GATEWAY_URL=http://10.66.0.2:8080   # WireGuard internal IP
INTERNAL_TOKEN=            # shared with US leg; openssl rand -hex 32
# ── Observability ──
SENTRY_DSN=
# ── Ports & binds (compose interpolation; not secrets) ──
IRAN_HTTP_PORT=8001        # local-profile caddy port
CORE_BIND=127.0.0.1        # real server: 10.66.0.1 (WireGuard IP) · CI: 0.0.0.0
