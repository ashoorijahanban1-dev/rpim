# IRAN leg env template. Copy via `make env-init` (generates secrets — never
# fill by hand with real values in the repo). Comments stay on their own
# lines: env-file parsers treat inline comments as part of the value.

# ── App ──
APP_ENV=production
APP_BASE_URL=https://app.your-domain.com
# openssl rand -hex 32 (env-init generates):
APP_SECRET_KEY=
# openssl rand -hex 32 (env-init generates):
JWT_SECRET=

# ── Data ──
# env-init sets: rpim
POSTGRES_USER=
# env-init generates (openssl rand -hex 32):
POSTGRES_PASSWORD=
# env-init sets: rpim
POSTGRES_DB=
# env-init composes; in-compose host is `postgres`:
DATABASE_URL=
# inside compose the service hostname `redis` is set per-service:
REDIS_URL=redis://localhost:6379/0

# ── Domestic channels (M7) ──
BALE_BOT_TOKEN=
EITAA_TOKEN=
# end of phase 1:
ZARINPAL_MERCHANT_ID=
# phase 2:
KAVENEGAR_API_KEY=

# ── Bridge to US leg ──
# WireGuard internal IP of the us leg:
GATEWAY_URL=http://10.66.0.2:8080
# shared with US leg — must be identical there; env-init generates + syncs:
INTERNAL_TOKEN=

# ── Observability ──
SENTRY_DSN=

# ── Ports & binds (compose interpolation; not secrets) ──
# local-profile caddy port:
IRAN_HTTP_PORT=8001
# real server after WireGuard is up: 10.66.0.1 · CI: 0.0.0.0
CORE_BIND=127.0.0.1
# host port for core-api; on the US server 8000 is Coolify's panel → use 18000 there
CORE_PORT=8000
