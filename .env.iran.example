# IRAN leg env template. Copy via `make env-init` (generates secrets — never
# fill by hand with real values in the repo). Comments stay on their own
# lines: env-file parsers treat inline comments as part of the value.

# ── App ──
APP_ENV=production
APP_BASE_URL=https://app.your-domain.com
# openssl rand -hex 32 (env-init generates):
APP_SECRET_KEY=
# openssl rand -hex 32 (env-init generates):
JWT_SECRET=

# ── Data ──
# env-init sets: rpim
POSTGRES_USER=
# env-init generates (openssl rand -hex 32):
POSTGRES_PASSWORD=
# env-init sets: rpim
POSTGRES_DB=
# env-init composes; in-compose host is `postgres`:
DATABASE_URL=
# inside compose the service hostname `redis` is set per-service:
REDIS_URL=redis://localhost:6379/0

# ── Domestic channels (M7) ──
# fake = dry-run outbox; set to live ONLY when real publishing should start:
PUBLISH_MODE=fake
BALE_BOT_TOKEN=
EITAA_BOT_TOKEN=
# end of phase 1:
ZARINPAL_MERCHANT_ID=
# phase 2 — SMS via SMS.ir (ADR 0028; official REST API only, rule 5):
SMSIR_API_KEY=
SMSIR_LINE_NUMBER=

# ── Bridge to US leg ──
# WireGuard internal IP of the us leg:
GATEWAY_URL=http://10.66.0.2:8080
# shared with US leg — must be identical there; env-init generates + syncs:
INTERNAL_TOKEN=

# ── Observability ──
SENTRY_DSN=

# ── Backup (M10 — scripts/backup.sh, values NEVER in repo) ──
# AES-256 passphrase; losing it makes artifacts unrecoverable. Off-site sync
# of the .enc files is the operator's nightly cron (docs/ops/runbook.md):
BACKUP_PASSPHRASE=

# ── Ports & binds (compose interpolation; not secrets) ──
# local-profile caddy port:
IRAN_HTTP_PORT=8001
# real server after WireGuard is up: 10.66.0.1 · CI: 0.0.0.0
CORE_BIND=127.0.0.1
# host port for core-api; on the US server 8000 is Coolify's panel → use 18000 there
CORE_PORT=8000

# ── WordPress REST publishing (M7c) — names only, values in Coolify (rule 4) ──
WORDPRESS_BASE_URL=
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# ── CRM lead bridge (M13) — names only, values in Coolify (rule 4) ──
# fake = dry-run outbox; live posts lead events to the webhook:
CRM_MODE=fake
CRM_WEBHOOK_URL=
CRM_WEBHOOK_TOKEN=

# ── App timezone (ADR 0032 — operator mandate, single revert lever) ──
RPIM_TIMEZONE=America/Los_Angeles
TZ=America/Los_Angeles

# ── Channel-credential vault (M16, ADR 0033) — set ONCE, rotating orphans sealed secrets ──
CHANNEL_SECRET_KEY=
# M24 v2 (ADR 0038): AES-GCM-256 key, base64 of 32 random bytes; v1 blobs
# stay readable and upgrade lazily on publish — set once, same rotation rule:
CHANNEL_SECRET_KEY_V2=

# ── Super Admin (M18, ADR 0035) — comma-separated admin emails; empty = nobody ──
# Operator mandate: the platform owner's email is the system admin.
ADMIN_EMAILS=info@ahmadi98.ir

# ── Radars (M19, ADR 0036) — comma-separated RSS/Atom URLs (syndication only) ──
# fake = deterministic simulated batch; live = real feeds:
TRENDS_MODE=fake
TRENDS_FEED_URLS=
AI_NEWS_MODE=fake
AI_NEWS_FEED_URLS=

# ── Visual engine (M21, ADR 0039) ──
# fake = deterministic bytes; remote = us-leg gateway /image:
IMAGE_MODE=fake
# container volume for media bytes (never in the DB):
MEDIA_STORAGE_DIR=/data/media
# dead-letter window — hours a job may keep failing before it stalls:
MAX_PUBLISH_RETRY_HOURS=24

# ── Metrics snapshot (M22, ADR 0041) — tenant-keyed clicks off the shared site ──
# fake = deterministic seam; umami = live (uses UMAMI_URL/SITE_ID/API_KEY):
METRICS_MODE=fake
# GA4 pull-with-cursor ingestion (M22 slice B, ADR 0042) — platform
# service-account JSON path (file on the leg, value never in repo):
GA4_MODE=fake
GA4_CREDENTIALS_FILE=
# first-run backfill window in days:
INGEST_BACKFILL_DAYS=7
