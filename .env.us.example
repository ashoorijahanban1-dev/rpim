# US leg env template. Copy via `make env-init`. Comments stay on their own
# lines: env-file parsers treat inline comments as part of the value.

APP_ENV=production
# same value as the iran leg — env-init syncs it:
INTERNAL_TOKEN=
# inside compose the service hostname `redis` is set per-service:
REDIS_URL=redis://localhost:6379/0

# ── Model chain (T1/T2, blueprint §5 — filled in M3) ──
GEMINI_API_KEY=
# second link in fallback chain:
DEEPSEEK_API_KEY=
# optional: if Claude wins T2:
ANTHROPIC_API_KEY=
# M17 openai_compat adapter — any OpenAI-compatible endpoint (e.g. GapGPT).
# Swap providers by changing these two vars; use as chain links like
# openai_compat:gpt-4o-mini. NOT a MODEL_T2 candidate until it passes the eval.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
# M21 image chain (ADR 0039) — provider:model links, e.g. openai:dall-e-3
# or gemini:imagen-3.0-generate-002; official APIs only (rule 5):
MODEL_IMG=
MODEL_IMG_FALLBACKS=
OPENAI_API_KEY=
# cheap bulk model:
MODEL_T1=
# comma-separated provider:model fallback links, e.g. deepseek:deepseek-chat:
MODEL_T1_FALLBACKS=
# winner of the 50-prompt eval (ADR 0031):
MODEL_T2=gemini:gemini-2.5-flash
# empty on purpose: no other candidate has passed the eval (ADR 0031)
MODEL_T2_FALLBACKS=
# per-link timeout in seconds:
MODEL_TIMEOUT_S=60

# ── Self-hosted embeddings (M2) ──
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# ── Crawler & publisher (M7+) ──
CRAWLER_MAX_CONCURRENCY=2
# phase 2:
PROXY_URL=
# fake = dry-run; set to live ONLY when real telegram publishing should start:
PUBLISH_MODE=fake
TELEGRAM_BOT_TOKEN=
SENTRY_DSN=

# ── Renderer (M8) ──
# fake = deterministic PNG (safe default); live = chromium screenshot:
RENDER_MODE=fake
# host bind/port; on the real server bind is the WireGuard IP 10.66.0.2:
RENDERER_BIND=127.0.0.1
RENDERER_PORT=8091

# ── Bridge to Iran leg ──
# WireGuard internal IP of the iran leg (wg healthcheck mode):
CORE_API_URL=http://10.66.0.1:8000

# ── Ports & binds (compose interpolation; not secrets) ──
# real server after WireGuard is up: 10.66.0.2 · CI: 0.0.0.0
GATEWAY_BIND=127.0.0.1
# host port for the gateway; Traefik often owns 8080 on servers → use 18080 there
GATEWAY_PORT=8080
# local-profile caddy port (loopback only):
US_HTTP_PORT=8002

# ── App timezone (ADR 0032 — operator mandate, single revert lever) ──
RPIM_TIMEZONE=America/Los_Angeles
TZ=America/Los_Angeles
