# ── Self-hosted embeddings ──
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# ── Crawler & publisher ──
CRAWLER_MAX_CONCURRENCY=2
PROXY_URL=                 # phase 2
TELEGRAM_BOT_TOKEN=
SENTRY_DSN=
