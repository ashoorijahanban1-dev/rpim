APP_ENV=production
INTERNAL_TOKEN=            # same value as Iran leg
REDIS_URL=redis://localhost:6379/0
# ── Model chain (T1/T2, blueprint §5) ──
GEMINI_API_KEY=
DEEPSEEK_API_KEY=          # second link in fallback chain
ANTHROPIC_API_KEY=         # optional: if Claude wins T2
MODEL_T1=                  # cheap bulk model
MODEL_T2=                  # winner of the 50-prompt eval — leave empty for now
# ── Self-hosted embeddings ──
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
# ── Crawler & publisher ──
CRAWLER_MAX_CONCURRENCY=2
PROXY_URL=                 # phase 2
TELEGRAM_BOT_TOKEN=
SENTRY_DSN=
# ── Bridge to Iran leg ──
CORE_API_URL=http://10.66.0.1:8000  # WireGuard internal IP (wg healthcheck mode)
# ── Ports & binds (compose interpolation; not secrets) ──
GATEWAY_BIND=127.0.0.1     # real server: 10.66.0.2 (WireGuard IP) · CI: 0.0.0.0
US_HTTP_PORT=8002          # local-profile caddy port (loopback only)
